from upstox_api.api import *

# Initialize Upstox session
upstox = Upstox(api_key, api_secret)

# Login and authenticate
upstox.set_session(token)
upstox.get_profile()

# Function to calculate the maximum quantity for buying
def calculate_max_buy_quantity(stock_symbol, available_funds, leverage):
    # Fetch the current market price of the stock
    stock_quote = upstox.get_live_feed(Instrument(stock_symbol, Exchange.NSE), LiveFeedType.LTP)
    stock_price = stock_quote['ltp']  # Last traded price
    
    # Calculate effective buying power
    buying_power = available_funds * leverage
    
    # Calculate the maximum number of shares you can buy
    max_buy_quantity = int(buying_power / stock_price)
    
    return max_buy_quantity

# Function to calculate the maximum quantity for selling
def calculate_max_sell_quantity(stock_symbol):
    # Fetch the user's holdings
    holdings = upstox.get_holdings()
    
    # Find the holding quantity for the given stock
    for holding in holdings:
        if holding['instrument']['symbol'] == stock_symbol:
            return int(holding['quantity'])
    
    return 0  # If no holdings are found

# Function to place a market order
def place_market_order(stock_symbol, quantity, transaction_type):
    order_params = {
        'symbol': stock_symbol,
        'quantity': quantity,
        'order_type': OrderType.MARKET,
        'transaction_type': transaction_type,
        'exchange': Exchange.NSE,
        'product_type': ProductType.MARGIN if transaction_type == TransactionType.BUY else ProductType.DELIVERY
    }
    
    upstox.place_order(**order_params)
    print(f'Placed a {transaction_type.name.lower()} order for {quantity} shares of {stock_symbol}.')

# Example Usage
stock_symbol = 'RELIANCE'  # Example stock symbol
available_funds = 100000    # Rs. 1,00,000 available for buying
leverage = 5               # 5x leverage provided by broker

# Quick Buy
max_buy_quantity = calculate_max_buy_quantity(stock_symbol, available_funds, leverage)
if max_buy_quantity > 0:
    place_market_order(stock_symbol, max_buy_quantity, TransactionType.BUY)
else:
    print('Insufficient funds to buy any shares.')

# Quick Sell
max_sell_quantity = calculate_max_sell_quantity(stock_symbol)
if max_sell_quantity > 0:
    place_market_order(stock_symbol, max_sell_quantity, TransactionType.SELL)
else:
    print(f'No holdings available to sell for {stock_symbol}.')
